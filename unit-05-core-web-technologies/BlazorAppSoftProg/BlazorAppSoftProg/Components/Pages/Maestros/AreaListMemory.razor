@page "/area"
@rendermode InteractiveServer
@using SoftProgDomain.RRRHH

<div class="container mt-4">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2 class="mb-0">Gestión de Áreas</h2>
        </div>
        <div class="col-auto">
            <button class="btn btn-success" @onclick="AddArea">
                + Agregar Área
            </button>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-light text-muted">Búsqueda rápida</span>
                        <input type="text" class="form-control" placeholder="Filtrar mientras escribes..." @bind="searchTerm" @bind:event="oninput" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-light text-muted">Búsqueda con Enter</span>
                        <input type="text" class="form-control" placeholder="Escribe y presiona Enter..." @bind="searchTermEnter" @onkeyup="HandleKeyUp" />
                        <button class="btn btn-outline-secondary" type="button" @onclick="ApplyEnterSearch">Buscar</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th scope="col" class="px-4 py-3">ID Área</th>
                            <th scope="col" class="px-4 py-3">Nombre</th>
                            <th scope="col" class="px-4 py-3 text-center">Estado</th>
                            <th scope="col" class="text-end px-4 py-3">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (FilteredAreas == null)
                        {
                            <tr>
                                <td colspan="4" class="text-center p-4">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Cargando...</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        else if (!FilteredAreas.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted p-4">No se encontraron áreas.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var area in FilteredAreas)
                            {
                                <tr>
                                    <td class="align-middle px-4 fw-bold">@area.IdArea</td>
                                    <td class="align-middle px-4">@area.Name</td>
                                    <td class="align-middle px-4 text-center">
                                        @if (area.Activa)
                                        {
                                            <span class="badge bg-success">Activa</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactiva</span>
                                        }
                                    </td>
                                    <td class="text-end px-4">
                                        <button class="btn btn-sm btn-primary me-2" @onclick="() => EditArea(area.IdArea)">
                                            Editar
                                        </button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteArea(area.IdArea)">
                                            Eliminar
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (showModal)
{
    <div class="modal fade show" tabindex="-1" style="display:block; background-color: rgba(0,0,0,0.5);" aria-modal="true" role="dialog">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(isEditing ? "Editar Área" : "Agregar Área")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nombre del Área</label>
                        <input type="text" class="form-control" @bind="currentArea.Name" placeholder="Ej. Recursos Humanos" />
                    </div>
                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="activaCheck" @bind="currentArea.Activa" />
                        <label class="form-check-label" for="activaCheck">Área Activa</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveArea">Guardar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Area> areas = new();
    private string searchTerm = string.Empty;
    private string searchTermEnter = string.Empty;
    private string appliedSearchTermEnter = string.Empty;

    // Modal state
    private Area currentArea = new();
    private bool showModal = false;
    private bool isEditing = false;

    protected override async Task OnInitializedAsync()
    {
        // Simulamos una carga de base de datos para no bloquear el hilo principal
        await Task.Delay(500);

        // Datos de prueba iniciales para poder ver el diseño y comportamiento de la tabla
        areas = new List<Area>
        {
            new Area { IdArea = 1, Name = "Recursos Humanos", Activa = true },
            new Area { IdArea = 2, Name = "Tecnología de la Información", Activa = true },
            new Area { IdArea = 3, Name = "Finanzas", Activa = true },
            new Area { IdArea = 4, Name = "Ventas", Activa = false },
            new Area { IdArea = 5, Name = "Marketing", Activa = true }
        };
    }

    private IEnumerable<Area> FilteredAreas
    {
        get
        {
            return areas.Where(a =>
                (string.IsNullOrWhiteSpace(searchTerm) && string.IsNullOrWhiteSpace(appliedSearchTermEnter)) ||
                (!string.IsNullOrWhiteSpace(searchTerm) && (a.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)) ||
                (!string.IsNullOrWhiteSpace(appliedSearchTermEnter) && (a.Name?.Contains(appliedSearchTermEnter, StringComparison.OrdinalIgnoreCase) ?? false))
            );
        }
    }

    private void HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            appliedSearchTermEnter = searchTermEnter;
        }
    }

    private void AddArea()
    {
        currentArea = new Area { Activa = true };
        isEditing = false;
        showModal = true;
    }

    private void EditArea(int id)
    {
        var areaToEdit = areas.FirstOrDefault(a => a.IdArea == id);
        if (areaToEdit != null)
        {
            currentArea = new Area
            {
                IdArea = areaToEdit.IdArea,
                Name = areaToEdit.Name,
                Activa = areaToEdit.Activa
            };
            isEditing = true;
            showModal = true;
        }
    }

    private void SaveArea()
    {
        if (string.IsNullOrWhiteSpace(currentArea.Name))
        {
            return; // Simple validation
        }

        if (isEditing)
        {
            var area = areas.FirstOrDefault(a => a.IdArea == currentArea.IdArea);
            if (area != null)
            {
                area.Name = currentArea.Name;
                area.Activa = currentArea.Activa;
            }
        }
        else
        {
            currentArea.IdArea = areas.Any() ? areas.Max(a => a.IdArea) + 1 : 1;
            areas.Add(currentArea);
        }

        showModal = false;
    }

    private void DeleteArea(int id)
    {
        var area = areas.FirstOrDefault(a => a.IdArea == id);
        if (area != null)
        {
            areas.Remove(area);
        }
    }

    private void CloseModal()
    {
        showModal = false;
    }
    private void ApplyEnterSearch(MouseEventArgs args)
    {
        throw new NotImplementedException();
    }
}
